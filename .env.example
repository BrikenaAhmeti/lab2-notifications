NODE_ENV=development
PORT=3005

JWT_ACCESS_SECRET=replace-with-auth-service-access-secret
INTERNAL_API_KEY=replace-with-shared-internal-service-key
CORS_ORIGIN=http://localhost:5173
SWAGGER_ENABLED=true

POSTGRES_USER=medsphere
POSTGRES_PASSWORD=medsphere
POSTGRES_DB=medsphere_notifications
POSTGRES_PORT=5432
DATABASE_URL=postgresql://medsphere:medsphere@localhost:5432/medsphere_notifications?schema=public
# Docker service URL:
# DATABASE_URL=postgresql://medsphere:medsphere@postgres:5432/medsphere_notifications?schema=public

REDIS_PASSWORD=medsphere_redis_password
REDIS_PORT=6379
REDIS_URL=redis://:medsphere_redis_password@localhost:6379
# Docker service URL:
# REDIS_URL=redis://:medsphere_redis_password@redis:6379

MONGO_ROOT_USERNAME=medsphere
MONGO_ROOT_PASSWORD=medsphere
MONGO_DATABASE=medsphere_notifications
MONGO_PORT=27017
MONGODB_URL=mongodb://medsphere:medsphere@localhost:27017/medsphere_notifications?authSource=admin
# Docker service URL:
# MONGODB_URL=mongodb://medsphere:medsphere@mongodb:27017/medsphere_notifications?authSource=admin

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM=notifications@medsphere.local
CORE_SERVICE_URL=http://localhost:3007
APPOINTMENT_REMINDER_JOB_ENABLED=true

NOTIFICATION_SERVICE_PORT=3005
